#VRML V2.0 utf8

Background { skyColor 0.6 0.7 0.8 }

PROTO MyOrientation [
	field SFVec3f pos 0 0 0
	field SFVec3f up  1 0 0
	field SFVec3f at  0 1 0
	field SFVec3f scale  1 1 1
	exposedField MFNode children []
] {
	DEF trans Transform {
		scale IS scale
		translation IS pos
		children IS children
	}
	DEF script Script {
		field SFVec3f xVec IS up
		field SFVec3f yVec IS at
		eventOut SFRotation rotation_changed
		url "javascript:
			function initialize() {
				var xVecN = xVec.normalize( );
				var yVecN = yVec.normalize( );
				var zVecN = xVecN.cross(yVecN);
				var mat = new VrmlMatrix( xVecN.x,xVecN.y,xVecN.z,0, yVecN.x,yVecN.y,yVecN.z,0,  zVecN.x,zVecN.y,zVecN.z,0, 0,0,0,1 );
				var rot = new SFRotation(0,0,0,0);
				mat.getTransform(null,rot);
				rotation_changed = rot;
			}
		"
	}
	ROUTE script.rotation_changed TO trans.rotation
}

PROTO Static_AxisCross [
	field MFString string []
	field SFVec3f scale 1 1 1
] {
	Transform { scale IS scale
		children [
			Billboard { axisOfRotation 0 0 0
				children [
					Transform { translation 0 3 0 scale 3 3 3 children [
						Shape {
							appearance Appearance { material Material { diffuseColor 1 1 0 } }
							geometry Text { string IS string fontStyle FontStyle { justify [ "MIDDLE" "END" ] family "SANSSERIF"} }
						}
					]}
				]
			}
			Shape { appearance Appearance { material Material { diffuseColor 1 1 1 } } geometry DEF sphere Sphere { radius 1 } }
			Transform { translation 2 0 0 children [ Shape { appearance Appearance { material Material { diffuseColor 1 0 0 } } geometry USE sphere } ] }
			Transform { translation 0 2 0 children [ Shape { appearance Appearance { material Material { diffuseColor 0 1 0 } } geometry USE sphere } ] }
			Transform { translation 0 0 2 children [ Shape { appearance Appearance { material Material { diffuseColor 0 0 1 } } geometry USE sphere } ] }
		]
	}
}

PROTO AxisCross [
	field MFString string []
	field SFVec3f scale 1 1 1
	field SFColor textColor 1 1 0
] {
	DEF proxy ProximitySensor { size 600 600 600 }
	DEF script Script {
		field MFString string IS string
		eventIn SFBool proxy_activated
		eventIn SFVec3f viewerPos_changed
		eventOut SFVec3f setScale
		eventOut SFVec3f setTextOffset
		url "javascript:
			// min:   distance:  10   size: 0.04
			// max:   distance: 300   size: 1.20
			function proxy_activated ( isActive ) {
				setScale = new SFVec3f(1.2,1.2,1.2);
			}
			function viewerPos_changed ( pos ) {
				var distance = pos.length();
				size = distance/10*0.05;
				if (size < 0.04) size = 0.04;
				if (size > 1.2) size = 1.2;
				setScale = new SFVec3f(size,size,size);
			}
			function initialize() {
				setTextOffset = new SFVec3f(0,string.length*3,0);
			}
		"
	}
	DEF trans Transform { scale 1.2 1.2 1.2 #scale IS scale
		children [
			Billboard { axisOfRotation 0 0 0
				children [
					DEF text_trans Transform { translation 0 3 0 scale 3 3 3 children [
						Shape {
							appearance Appearance { material Material { diffuseColor IS textColor } }
							geometry Text { string IS string fontStyle FontStyle { justify [ "MIDDLE" "END" ] family "SANSSERIF"} }
						}
					]}
				]
			}
			Shape { appearance Appearance { material Material { diffuseColor 1 1 1 } } geometry DEF sphere Sphere { radius 1 } }
			Transform { translation 2 0 0 children [ Shape { appearance Appearance { material Material { diffuseColor 1 0 0 } } geometry USE sphere } ] }
			Transform { translation 0 2 0 children [ Shape { appearance Appearance { material Material { diffuseColor 0 1 0 } } geometry USE sphere } ] }
			Transform { translation 0 0 2 children [ Shape { appearance Appearance { material Material { diffuseColor 0 0 1 } } geometry USE sphere } ] }
		]
	}
	ROUTE proxy.isActive TO script.proxy_activated
	ROUTE proxy.position_changed TO script.viewerPos_changed
	ROUTE script.setScale TO trans.scale
	ROUTE script.setTextOffset TO text_trans.translation
}

PROTO MessPunkt [
	field MFString string []
	field SFVec3f pos 0 0 0
	field SFBool addPosToStrings TRUE
	field SFColor textColor 1 1 1
] {
	DEF script Script {
		field SFVec3f pos IS pos
		field SFBool addPosToStrings IS addPosToStrings
		field MFString string IS string
		eventIn SFBool proxy_activated
		eventIn SFVec3f viewerPos_changed
		eventOut SFVec3f setScale
		eventOut SFVec3f setTextOffset
		eventOut MFString setText
		url "javascript:
			// min:   distance:  10   size: 0.04
			// max:   distance: 300   size: 1.20
			function proxy_activated ( isActive ) {
				setScale = new SFVec3f(1.2,1.2,1.2);
			}
			function viewerPos_changed ( pos ) {
				var distance = pos.length();
				size = distance/10*0.04;
				if (size < 0.04) size = 0.04;
				if (size > 1.2) size = 1.2;
				setScale = new SFVec3f(size,size,size);
			}
			function initialize() {
				setTextOffset = new SFVec3f(0,string.length*3,0);
				if (addPosToStrings)
					string[string.length] = pos.toString();
				setText = string;
			}
		"
	}
	Transform { translation IS pos
		children [
			DEF proxy ProximitySensor { size 600 600 600 }
			DEF trans Transform { scale 1.2 1.2 1.2
				children [
					Billboard { axisOfRotation 0 0 0
						children [
							DEF text_trans Transform { translation 0 3 0 scale 3 3 3 children [
								Shape {
									appearance Appearance { material Material { diffuseColor IS textColor } }
									geometry DEF text_obj Text { fontStyle FontStyle { justify [ "MIDDLE" "END" ] family "SANSSERIF"} }
								}
							]}
						]
					}
					Transform { scale 3 3 3
						children [
							Shape { appearance Appearance { material Material { emissiveColor 1 0 0 } } geometry IndexedLineSet { coord Coordinate { point [ -1  0  0, 1 0 0, 0.5 0.1 0.0, 0.5 0.0 0.1, 1 0 0 ] } coordIndex [ 0 1 2 3 4 ] } }
							Shape { appearance Appearance { material Material { emissiveColor 0 1 0 } } geometry IndexedLineSet { coord Coordinate { point [  0 -1  0, 0 1 0, 0.0 0.5 0.1, 0.1 0.5 0.0, 0 1 0 ] } coordIndex [ 0 1 2 3 4 ] } }
							Shape { appearance Appearance { material Material { emissiveColor 0 0 1 } } geometry IndexedLineSet { coord Coordinate { point [  0  0 -1, 0 0 1, 0.1 0.0 0.5, 0.0 0.1 0.5, 0 0 1 ] } coordIndex [ 0 1 2 3 4 ] } }
						]
					}
				]
			}
		]
	}
	ROUTE proxy.isActive TO script.proxy_activated
	ROUTE proxy.position_changed TO script.viewerPos_changed
	ROUTE script.setScale TO trans.scale
	ROUTE script.setTextOffset TO text_trans.translation
	ROUTE script.setText TO text_obj.string
}

PROTO SingleText [
	field MFString string []
	field SFColor textColor 0 0 0.5
] {
	Transform { scale 0.5 0.5 0.5 rotation 0 1 0 1.5707963
		children Shape {
			appearance Appearance { material Material { diffuseColor IS textColor } }
			geometry Text { string IS string fontStyle FontStyle { justify [ "MIDDLE" "END" ] family "SANSSERIF"} }
		}
	}
}
